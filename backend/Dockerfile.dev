# ============================================================
# Flowmanner Backend — Development Dockerfile
# ============================================================
# Lightweight single-stage image with hot-reload support.
# Used by the self-contained dev compose at dev/docker-compose.dev.yml.
#
# Source code is mounted as a volume at runtime (not baked in),
# enabling instant hot-reload with uvicorn --reload.
# ============================================================

FROM python:3.11.11-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Install runtime system deps (git needed for pip git+https dependencies)
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        curl \
        git \
        libpq5 \
        postgresql-client \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python dependencies (cached layer — only rebuilds when requirements.txt changes)
COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir --upgrade pip setuptools wheel \
    && pip install --no-cache-dir -r /app/requirements.txt

# Copy only the files needed at build time that are NOT volume-mounted:
# - mcp_gateway and agent_definitions (not in the app/ volume mount)
# The app/, alembic/, and alembic.ini are mounted at runtime from the host.
COPY mcp_gateway/ /app/mcp_gateway/
COPY agent_definitions/ /app/agent_definitions/

# Create uploads directory
RUN mkdir -p /app/uploads

EXPOSE 8000

# The CMD is always overridden by the compose file's entrypoint.
# This image has no baked-in app code — it relies on volume mounts.
CMD ["uvicorn", "app.main_fastapi:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--log-level", "info"]
